# Cole estas variaveis em Railway > Service > Variables.
# Nao defina PORT: a Railway injeta essa variavel automaticamente.

NODE_ENV=production

# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_ADMIN_ROLE_ID=
DISCORD_LOG_CHANNEL_ID=

# App
STORE_NAME=NexusSellBot
PUBLIC_BASE_URL=https://seu-app.up.railway.app
DATABASE_PATH=/app/data/store.sqlite
DEFAULT_CURRENCY=BRL
ORDER_EXPIRATION_MINUTES=60
LOW_STOCK_ALERT_AT=3

# Painel
PANEL_PASSWORD=
PANEL_SESSION_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAYMENT_METHODS=

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Pagar.me / Stone
PAGARME_SECRET_KEY=
PAGARME_BASE_URL=https://api.pagar.me/core/v5
PAGARME_PAYMENT_METHODS=credit_card,pix,boleto
PAGARME_WEBHOOK_SECRET=

# Asaas
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_CUSTOMER_ID=
