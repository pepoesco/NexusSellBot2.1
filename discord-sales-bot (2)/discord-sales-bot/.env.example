# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Use guild commands while testing. Leave empty to register global commands.
DISCORD_GUILD_ID=
DISCORD_ADMIN_ROLE_ID=
DISCORD_LOG_CHANNEL_ID=

# Store
STORE_NAME=NexusSellBot
PUBLIC_BASE_URL=https://your-domain.example
PORT=3000
DATABASE_PATH=./data/store.sqlite
DEFAULT_CURRENCY=BRL
ORDER_EXPIRATION_MINUTES=60
LOW_STOCK_ALERT_AT=3
PANEL_PASSWORD=
PANEL_SESSION_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional comma list, example: card,pix,boleto. Empty lets Stripe choose available methods.
STRIPE_PAYMENT_METHODS=

# Mercado Pago / Pix / boleto / cards in Brazil
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Pagar.me / Stone
PAGARME_SECRET_KEY=
PAGARME_BASE_URL=https://api.pagar.me/core/v5
PAGARME_PAYMENT_METHODS=credit_card,pix,boleto
PAGARME_WEBHOOK_SECRET=

# Asaas / Pix / boleto / card
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_CUSTOMER_ID=
ASAAS_BILLING_TYPE=PIX
ASAAS_WEBHOOK_TOKEN=

# Efibank / Efi Pay Pix
EFIBANK_CLIENT_ID=
EFIBANK_CLIENT_SECRET=
EFIBANK_CERTIFICATE_PATH=
# Use base64 instead of path if preferred. Keep EFIBANK_CERTIFICATE_PATH empty.
EFIBANK_CERTIFICATE_BASE64=
EFIBANK_SANDBOX=true
EFIBANK_PIX_KEY=
EFIBANK_WEBHOOK_SECRET=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_WEBHOOK_ID=

# Manual Pix / bank transfer
PIX_KEY=
PIX_RECEIVER_NAME=
PIX_CITY=Sao Paulo
PIX_DESCRIPTION=Pedido NexusSellBot
MANUAL_BANK_INSTRUCTIONS=

# Itau Pix Recebimentos
ITAU_CLIENT_ID=
ITAU_CLIENT_SECRET=
ITAU_ENV=sandbox
ITAU_PIX_KEY=
# Production normally requires mTLS certificate and key.
ITAU_CERT_PATH=./certs/itau-cert.crt
ITAU_KEY_PATH=./certs/itau-key.key
ITAU_CERT_BASE64=
ITAU_KEY_BASE64=
ITAU_CERT_PASSPHRASE=
# Leave empty to use defaults for sandbox/production.
ITAU_TOKEN_URL=
ITAU_PIX_BASE_URL=
ITAU_WEBHOOK_SECRET=

# PagSeguro
PAGSEGURO_EMAIL=
PAGSEGURO_TOKEN=
PAGSEGURO_ENV=sandbox

# Cielo E-commerce Pix
CIELO_MERCHANT_ID=
CIELO_MERCHANT_KEY=
CIELO_ENV=sandbox
CIELO_PAYMENT_TYPE=Pix
CIELO_WEBHOOK_SECRET=

# Adyen Pay by Link
ADYEN_API_KEY=
ADYEN_MERCHANT_ACCOUNT=
ADYEN_CHECKOUT_BASE_URL=
ADYEN_ENV=test
ADYEN_COUNTRY_CODE=BR
ADYEN_SHOPPER_LOCALE=pt-BR
ADYEN_HMAC_KEY=

# Square Online Checkout
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENV=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_URL=

# Mollie
MOLLIE_API_KEY=
MOLLIE_METHODS=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Universal adapter for any provider that can POST a signed webhook.
CUSTOM_WEBHOOK_SECRET=
CUSTOM_CHECKOUT_URL_TEMPLATE=
