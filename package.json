{
  "name": "nexus-sell-bot",
  "version": "1.0.0",
  "description": "NexusSellBot: bot de vendas para Discord com catalogo, pedidos, estoque e pagamentos modulares.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "register": "tsx src/register-commands.ts",
    "seed": "tsx src/seed.ts",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@adyen/api-library": "^30.1.0",
    "@mollie/api-client": "^4.5.0",
    "better-sqlite3": "^12.10.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.8.0",
    "helmet": "^8.1.0",
    "mercadopago": "^3.1.0",
    "pagarme": "^4.35.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "razorpay": "^2.9.6",
    "sdk-node-apis-efi": "^1.3.1",
    "square": "^44.1.0",
    "stripe": "^22.2.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20"
  }
}
